# ===========================================
# IkoniK Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local — it is in .gitignore.
# ===========================================

# Anthropic (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=

# Supabase (public — safe for client, RLS enforces security)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# OAuth provider secrets are configured in the Supabase Dashboard
# (Authentication > Providers), NOT here. See README for setup instructions.
